datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model ChickenItem {
  id              String   @id
  name            String
  tag             String
  description     String
  footerText      String
  image           String
  origin          String
  weightRange     String
  age             String
  characterDetail String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
